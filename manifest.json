{
  "manifest_version": 3,
  "name": "Reopen Closed Tab",
  "version": "1.0.0",
  "description": "Reopen the most recently closed tab or window with a single toolbar click.",
  "permissions": ["sessions"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Reopen Closed Tab",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
